<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.collections.*?>
<?import java.lang.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.image.*?>
<?import de.jensd.fx.glyphs.fontawesome.FontAwesomeIconView?>
<?import javafx.geometry.Insets?>



<VBox  fx:id="settingsRoot"
       styleClass="settings-root"
       xmlns="http://javafx.com/javafx/8.0.171" 
       xmlns:fx="http://javafx.com/fxml/1" 
       fx:controller="com.coursehelper.frontend.controllers.SettingsPageController"
       maxWidth="Infinity"
       spacing="30"
       >

       <Label text="Settings" alignment="CENTER" styleClass="section-title" maxWidth="Infinity"/>

       <VBox>
              <!-- change display photo -->
              <HBox styleClass="component-hbox" spacing="5" alignment="CENTER">
                     <VBox fx:id="profilePhotoContainer" spacing="15" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                            <Label text="Profile picture" styleClass="form-label"/>
                            <ImageView fx:id="profileImageView"
                                   fitWidth="80" fitHeight="80"
                                   preserveRatio="true"
                                   style="-fx-cursor: hand;"/>
                     </VBox>
                     <Button text="Upload" styleClass="edit-btn" onMouseClicked="#uploadProfilePhoto"/>

              </HBox>

              <!-- change username  -->
              <VBox styleClass="component-hbox" spacing="10">
                     <HBox alignment="CENTER">
                            <Label fx:id="usernameLabel" styleClass="form-label"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button fx:id="changeUsernameBtn" text="Change Username" styleClass="edit-btn" onAction="#toggleUsernameEdit"/>
                     </HBox>
                     <HBox fx:id="usernameEditRow" spacing="10" alignment="CENTER" visible="false" managed="false">
                            <TextField fx:id="newUsernameField" promptText="New username" HBox.hgrow="ALWAYS"/>
                            <Button text="Save" styleClass="edit-btn save-btn" onAction="#saveUsername"/>
                            <Button text="Cancel" styleClass="edit-btn cancel-edit-btn" onAction="#cancelUsernameEdit"/>
                     </HBox>
                     <Label fx:id="usernameError" styleClass="error-label" text="" visible="false" managed="false"/>
              </VBox>

              <!-- change password -->
              <VBox styleClass="component-hbox" spacing="10">
                     <HBox alignment="CENTER">
                            <Label styleClass="form-label" text="Password"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button fx:id="changePasswordBtn" text="Change Password" styleClass="edit-btn" onAction="#togglePasswordEdit"/>
                     </HBox>
                     <VBox fx:id="passwordEditSection" spacing="8" visible="false" managed="false">
                            <PasswordField fx:id="currentPasswordField" promptText="Current password"/>
                            <PasswordField fx:id="newPasswordField" promptText="New password"/>
                            <PasswordField fx:id="confirmPasswordField" promptText="Confirm new password"/>
                            <HBox spacing="10">
                                   <Button text="Save" styleClass="edit-btn save-btn" onAction="#savePassword"/>
                                   <Button text="Cancel" styleClass="edit-btn cancel-edit-btn" onAction="#cancelPasswordEdit"/>
                            </HBox>
                     </VBox>
                     <Label fx:id="passwordError" styleClass="error-label" text="" visible="false" managed="false"/>
              </VBox>
                     


              <!-- set current semester  -->
              <VBox spacing="10" styleClass="component-hbox">
                     <HBox alignment="CENTER" spacing="10">
                            <VBox spacing="5" HBox.hgrow="ALWAYS">
                                   <Label text="Current Semester:" styleClass="form-label"/>
                                   <ComboBox fx:id="semesterCombo" prefWidth="200" promptText="Select semester" disable="true">
                                          <items>
                                                 <FXCollections fx:factory="observableArrayList">
                                                        <String fx:value="FALL" />
                                                        <String fx:value="SPRING" />
                                                        <String fx:value="SUMMER" />
                                                 </FXCollections>
                                          </items>
                                   </ComboBox>
                            </VBox>
                            <VBox spacing="5" HBox.hgrow="ALWAYS">
                                   <Label text="Current Year" styleClass="form-label"/>
                                   <ComboBox fx:id="yearCombo" prefWidth="200" promptText="Select year" disable="true"/>
                            </VBox>
                            <Button fx:id="editSemesterBtn" text="Change Semester" styleClass="edit-btn" onAction="#toggleSemesterEdit"/>
                     </HBox>

                     <VBox fx:id="semesterEditSection" spacing="8" visible="false" managed="false">
                            <VBox spacing="5">
                                   <Label text="Semester Start" styleClass="form-label"/>
                                   <DatePicker fx:id="startDatePicker" prefWidth="200"/>
                            </VBox>
                            <VBox spacing="5">
                                   <Label text="Semester End" styleClass="form-label"/>
                                   <DatePicker fx:id="endDatePicker" prefWidth="200"/>
                            </VBox>
                            <HBox spacing="10">
                                   <Button text="Save" styleClass="edit-btn save-btn" onAction="#saveSemester"/>
                                   <Button text="Cancel" styleClass="edit-btn cancel-edit-btn" onAction="#cancelSemesterEdit"/>
                            </HBox>
                     </VBox>

                     <Label fx:id="errorLabel" styleClass="error-label" text="" visible="false" managed="false"/>

              </VBox>
              

       </VBox>



</VBox>