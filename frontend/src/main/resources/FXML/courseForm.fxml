<?xml version="1.0" encoding="UTF-8"?>


<?import org.controlsfx.control.CheckComboBox?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.collections.*?>
<?import java.lang.*?>
<?import javafx.geometry.Insets?>


<VBox styleClass="root-container" spacing="15" alignment="CENTER_LEFT" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.coursehelper.frontend.controllers.AddCourseFormController">

    <!-- Popup Title -->
    <HBox alignment="CENTER_LEFT">
        <Label text="Add New Course" styleClass="section-title"/>
    </HBox>

    <VBox spacing="5">

        <!-- current semester and year prefilled -->
        <HBox spacing="5" alignment="CENTER_LEFT">
            <Label text="Current Semester:" styleClass="form-label" prefWidth="100" minWidth="100"/>
            <Label fx:id="semesterYearLabel" text=""/>
        </HBox>

         <!-- Course Name -->
        <HBox spacing="5" alignment="CENTER_LEFT">
            <Label text="Course Name:" styleClass="form-label" prefWidth="100" minWidth="100"/>
            <TextField fx:id="course_name" prefWidth="200"/>
        </HBox>
        
        
        <!-- For extention -->
        <!-- <HBox spacing="5" alignment="CENTER_LEFT">
            <Label text="Semester:" styleClass="form-label" prefWidth="100" minWidth="100"/>
            <ComboBox fx:id="semester_combo" prefWidth= "125" maxWidth="125">
                <items>
                    <FXCollections fx:factory="observableArrayList">
                    <String fx:value="FALL" />
                    <String fx:value="SPRING" />
                    <String fx:value="SUMMER" />
                    </FXCollections>
                </items>
            </ComboBox>
        </HBox>
        
    
        <HBox spacing="5" alignment="CENTER_LEFT">
        <Label text="Year:" styleClass="form-label" prefWidth="100" minWidth="100"/>
            <ComboBox fx:id="year_combo" prefWidth= "100" maxWidth="100"/>
        </HBox> -->

        
        <!-- Start Time -->
        <HBox spacing="5" alignment="CENTER_LEFT">
            <Label text="Start Time:" styleClass="form-label" prefWidth="100" minWidth="100"/>
            <ComboBox fx:id="start_time_combo" prefWidth= "150" maxWidth="150"/>
        </HBox>

        <!-- End Time -->
        <HBox spacing="5" alignment="CENTER_LEFT">
            <Label text="End Time:" styleClass="form-label" prefWidth="100" minWidth="100"/>
            <ComboBox fx:id="end_time_combo" prefWidth= "150" maxWidth="150"/>
        </HBox>

        <!-- Class Days -->
        <HBox spacing="5" alignment="CENTER_LEFT">
            <Label text="Lecture Days:" styleClass="form-label" prefWidth="100" minWidth="100"/>
            <CheckComboBox fx:id="select_days_checkComboBox" prefWidth= "125" maxWidth="125"/>
        </HBox>

        <!-- Course Style(color) -->
        <HBox spacing="5" alignment="CENTER_LEFT">
            <Label text="Color:" styleClass="form-label" prefWidth="100" minWidth="100"/>
            <ComboBox fx:id="style_combo" />
        </HBox>
    
    </VBox>

    <Label fx:id="errorLabel" style="-fx-text-fill: red;"/>

    <!-- Submit and Cancel Buttons -->
    <HBox spacing="5" alignment="CENTER">
        <Button fx:id="add_course_button" text="add" prefWidth= "80" maxWidth="80" onAction="#addCourse" styleClass="add-btn"/>
        <Button fx:id="cancel_course_button" text="cancel" prefWidth= "80" maxWidth="80" onAction="#cancelCourse" styleClass="cancel-btn"/>
    </HBox>

    
</VBox>