<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.text.Text?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<?import de.jensd.fx.glyphs.fontawesome.FontAwesomeIconView?>



<VBox styleClass="nav-root" alignment="center" spacing="40" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml" fx:controller="com.coursehelper.frontend.controllers.NavigationController">
    <Text fx:id= "welcomeText" styleClass="welcome" />
     <ImageView fx:id="profileImageView"
               fitWidth="100" fitHeight="100"
               preserveRatio="true"
               style="-fx-cursor: hand;"/>


    <VBox spacing="20" alignment="center">
        <Hyperlink fx:id="homeLink" onAction="#goToHomePage" styleClass="nav-btn">
            <graphic>
                <FontAwesomeIconView glyphName="HOME" size="26" styleClass="nav-glyph"/>
            </graphic>
        </Hyperlink>

        <Hyperlink fx:id="documentsLink" onAction="#goToDocumentsPage" styleClass="nav-btn">
            <graphic>
                <FontAwesomeIconView glyphName="FILE" size="22" styleClass="nav-glyph"/>
            </graphic>
        </Hyperlink>


        <Hyperlink fx:id="tasksLink" onAction="#goToSettingsPage" styleClass="nav-btn">
            <graphic>
                <FontAwesomeIconView glyphName="GEARS" size="22" styleClass="nav-glyph"/>
            </graphic>
        </Hyperlink>
    </VBox>

</VBox>