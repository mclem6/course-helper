<?xml version="1.0" encoding="UTF-8"?>
<?import com.calendarfx.view.DetailedWeekView?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>

<VBox fx:id="root" spacing="50" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.coursehelper.frontend.controllers.SidebarController" >
    <VBox spacing="20">
        <Label fx:id="quoteLabel" styleClass="theme-text, quote-label" wrapText="true" text=""/>
        <HBox alignment="CENTER_RIGHT">
            <Label fx:id="authorLabel" styleClass="theme-text, author-label" text=""/>
        </HBox>
    </VBox>

    <!-- calendar section-->
    <VBox styleClass="calendar-vbox">
        <DetailedWeekView fx:id="calendarWeekView" prefHeight="200" prefWidth="300"/>
    </VBox>

    <!-- Due Soon section-->
    <VBox fx:id="dueDatePanel" spacing="8">
        <Label styleClass="section-title" text="Due Soon"/>
        <VBox fx:id="dueSoonList" styleClass="due-soon-vbox" spacing="6"/>
    </VBox>

    
</VBox>