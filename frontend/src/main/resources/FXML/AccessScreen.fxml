<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.Text?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.shape.Circle?>

<HBox fx:id="root" styleClass="root" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.coursehelper.frontend.controllers.AccessScreenController">
  
  <VBox  styleClass="left" prefWidth="364" prefHeight="555">
      <AnchorPane>
         <fx:define>
            <ToggleGroup fx:id="authGroup"/>
         </fx:define>

         <ToggleButton fx:id="tab_login" 
         text= "Login" 
         toggleGroup="$authGroup"
         styleClass="login-signup-btns"
         AnchorPane.topAnchor="230"
         AnchorPane.rightAnchor="75" />

         <ToggleButton fx:id="tab_signup" 
         text= "Sign Up" 
         toggleGroup="$authGroup"
         styleClass="login-signup-btns"
         AnchorPane.topAnchor="275"
         AnchorPane.rightAnchor="75" />
      </AnchorPane>

      <Region VBox.vgrow="ALWAYS"/>
        <VBox fx:id="toggle" alignment="CENTER" style="-fx-padding: 0 75 10 0;">
            <StackPane fx:id="themeToggle" styleClass="toggle-track" 
               prefWidth="50" 
               prefHeight="20"
               onMouseClicked="#onToggleTheme" >
               <children>
                     <Circle fx:id="toggleThumb" styleClass="toggle-thumb" radius="8"/>
               </children>
            </StackPane>
         </VBox>
  </VBox>


  <VBox alignment="center"> 
      <padding>
         <Insets top="20" right="20" bottom="20" left="100"/>
      </padding>
      <Label styleClass="app-name" text="Course Helper" />

      <VBox spacing="15" styleClass="access-container">
            <children>
                  <VBox spacing="10">
                     <Label text="Username" styleClass="un-pw-text"/>
                     <TextField fx:id="usernameText" styleClass="text-field"/>
                     <Label text="Password" styleClass="un-pw-text"/>
                     <PasswordField fx:id="passwordText" styleClass="password-field"/>
                  </VBox>

                  <Label fx:id="errorLabel" style="-fx-text-fill: red;" />

                  <HBox spacing="10">
                     <Button fx:id="logInButton" text="Log In" onAction="#handleLogin" styleClass="login-button" />
                     <Button fx:id="createAccountButton" text="Create Account" onAction="#createAccount" styleClass="login-button" visible="false" managed="false"/>
                  </HBox>

                  <VBox fx:id="loadingBox" visible="false" managed="false" alignment="CENTER" spacing="8">
                     <ProgressIndicator fx:id="loadingIndicator" prefWidth="36" prefHeight="36"/>
                     <Label text="Setting things up..." style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #888888;"/>
                  </VBox>
            </children> 
      </VBox>
   </VBox>



</HBox>
